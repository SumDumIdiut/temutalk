# ─── Spotify ───────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Set the Redirect URI to: http://localhost:3000/callback
# (Add your LAN IP too, e.g. http://192.168.1.100:3000/callback, for LAN auth)
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
REDIRECT_URI=http://localhost:3000/callback

# ─── Hub Settings ──────────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change_this_to_a_long_random_string

# ─── Weather ───────────────────────────────────────────────────────────────
# Default city (users can change it in the weather page UI)
WEATHER_CITY=London

# ─── Voice assistant (local Ollama) ────────────────────────────────────────
# Needs Ollama running with a tool-calling model pulled:
#   ollama pull llama3.1
# OLLAMA_URL=http://localhost:11434
# ASSISTANT_MODEL=llama3.1   # other options: qwen2.5, qwen3, mistral, llama3.2
# Speech-to-text for browsers without the Web Speech API + wake word:
# whisper.cpp server (see ~/.local/opt/whisper.cpp) on this URL
# WHISPER_URL=http://localhost:11435

# ─── Chat OAuth (optional) ─────────────────────────────────────────────────
# Discord: discord.com/developers/applications → OAuth2
# Redirect URI to add: https://YOUR_DOMAIN/auth/chat/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Google: console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Redirect URI to add: https://YOUR_DOMAIN/auth/chat/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
